rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chaque utilisateur ne peut lire/écrire QUE ses propres données
    // Structure : users/{userId}/controls, users/{userId}/homework, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Widget public : lecture libre, écriture réservée au propriétaire
    match /widget/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Tout le reste est refusé par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
