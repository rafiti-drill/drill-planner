# ─────────────────────────────────────────────────────────────
# Drill Planner Backend — Variables d'environnement
# Copier ce fichier en .env pour le développement local.
# Sur Railway, saisir ces variables dans :
#   Projet → Variables → Add Variable
# ─────────────────────────────────────────────────────────────

# Port (Railway le définit automatiquement, ne pas modifier)
PORT=3001

# ── Firebase Admin SDK ────────────────────────────────────────
# Récupérer ces valeurs depuis Firebase Console :
# Paramètres du projet → Comptes de service → Générer une clé privée
# Ouvrir le JSON téléchargé et copier chaque champ ci-dessous.

FIREBASE_PROJECT_ID=drill-planner-9a8eb
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@drill-planner-9a8eb.iam.gserviceaccount.com
# La clé privée contient des \n — coller la valeur ENTIÈRE entre guillemets
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
